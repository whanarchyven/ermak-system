# ===== Convex self-hosted =====
# Имя инстанса и секрет (от секрета зависит admin key — не меняйте после первого запуска)
INSTANCE_NAME=ermak
INSTANCE_SECRET=4f5e6d7c8b9a0a1b2c3d4e5f60718293a4b5c6d7e8f90a1b2c3d4e5f60718293

# Публичные origin'ы backend (как их видит браузер)
CONVEX_CLOUD_ORIGIN=http://localhost:3210
CONVEX_SITE_ORIGIN=http://localhost:3211

# Admin key проставляется автоматически скриптом scripts/up.sh при первом запуске
CONVEX_SELF_HOSTED_ADMIN_KEY=

# ===== URL backend для фронтендов (браузер + контейнер через socat) =====
PUBLIC_CONVEX_URL=http://localhost:3210

# Базовый URL приложения для Convex Auth (редиректы)
SITE_URL=http://localhost:3001

# ===== Порты (host) =====
CONVEX_PORT=3210
CONVEX_SITE_PORT=3211
DASHBOARD_PORT=6791
ERP_PORT=3000
PWA_PORT=3001

# ===== Сид: учётка администратора ERP =====
SEED_ADMIN_EMAIL=admin@ermak.local
SEED_ADMIN_PASSWORD=admin123


